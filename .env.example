COMPOSE_PROJECT_NAME=puqme
NODE_ENV=development

POSTGRES_DB=puqme
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

REDIS_PORT=6379

API_PORT=3000
WEBSOCKET_PORT=3010
WEB_PORT=3001
ADMIN_PORT=3002

GHCR_NAMESPACE=ghcr.io/puqme
DEPLOY_ENVIRONMENT=staging
IDRIVE_E2_ENDPOINT=https://storage.idrivee2-7.com
IDRIVE_E2_REGION=auto
IDRIVE_E2_ACCESS_KEY=replace-me
IDRIVE_E2_SECRET_KEY=replace-me
IDRIVE_E2_BUCKET_IMAGES=puq-images
IDRIVE_E2_BUCKET_AVATARS=puq-avatars
IDRIVE_E2_BUCKET_CHAT_MEDIA=puq-chat-media
IDRIVE_E2_BUCKET_BACKUPS=puq-backups
CLOUDFLARE_ZONE=puq.me
