{
  "Rules": [
    {
      "ID": "abort-incomplete-multipart-uploads",
      "Status": "Enabled",
      "AbortIncompleteMultipartUpload": {
        "DaysAfterInitiation": 3
      },
      "Filter": {
        "Prefix": ""
      }
    },
    {
      "ID": "expire-temporary-chat-uploads",
      "Status": "Enabled",
      "Expiration": {
        "Days": 30
      },
      "Filter": {
        "Prefix": "chat/tmp/"
      }
    }
  ]
}
