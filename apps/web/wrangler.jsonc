{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "puqme-web",
  "pages_build_output_dir": ".open-next",
  "compatibility_date": "2026-03-17",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "NEXT_PUBLIC_APP_ENV": "production"
  }
}
