{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "puqme-web",
  // OpenNext builds to .open-next/ with worker.js as entry point.
  // The Pages build command creates _worker.js (required by Cloudflare Pages advanced mode)
  // that re-exports from worker.js to enable the Worker function.
  "pages_build_output_dir": ".open-next",
  "compatibility_date": "2026-03-17",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "NEXT_PUBLIC_APP_ENV": "production",
    "NEXT_PUBLIC_APP_URL": "https://puq.me",
    "NEXT_PUBLIC_API_BASE_URL": "https://api.puq.me",
    "NEXT_PUBLIC_WS_BASE_URL": "wss://ws.puq.me"
  }
}
