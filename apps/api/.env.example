NODE_ENV=development
DEV_MOCK_MODE=true
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
APP_ORIGIN=http://localhost:3001
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-second-long-random-secret
JWT_REFRESH_EXPIRES_IN=30d
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/puqme
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=https://storage.idrivee2-7.com
S3_REGION=auto
S3_BUCKET=puq-images
STORAGE_AVATARS_BUCKET=puq-avatars
STORAGE_IMAGES_BUCKET=puq-images
STORAGE_CHAT_MEDIA_BUCKET=puq-chat-media
STORAGE_BACKUPS_BUCKET=puq-backups
S3_ACCESS_KEY=replace-me
S3_SECRET_KEY=replace-me
S3_PUBLIC_BASE_URL=https://cdn.puq.me
CDN_BASE_URL=https://cdn.puq.me
MALWARE_SCAN_HOOK_URL=
# production hosting baseline:
# APP_ORIGIN=https://puq.me
# S3_PUBLIC_BASE_URL=https://cdn.puq.me
# CDN_BASE_URL=https://cdn.puq.me
MEDIA_MAX_UPLOAD_SIZE_BYTES=10485760
MEDIA_MAX_PROFILE_PHOTOS=6
UPLOAD_AVATAR_MAX_BYTES=5242880
UPLOAD_IMAGE_MAX_BYTES=10485760
UPLOAD_CHAT_MEDIA_MAX_BYTES=26214400
RATE_LIMIT_MAX=250
RATE_LIMIT_WINDOW="1 minute"
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_LOGIN_RATE_LIMIT_WINDOW="15 minutes"
EXPERIMENT_SALT=replace-with-a-stable-experiment-salt
