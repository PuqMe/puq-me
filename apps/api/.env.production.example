NODE_ENV=production
DEV_MOCK_MODE=false
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
APP_ORIGIN=https://puq.me
JWT_SECRET=<generate-with-openssl-rand-base64-48>
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<generate-with-openssl-rand-base64-48>
JWT_REFRESH_EXPIRES_IN=30d
DATABASE_URL=postgresql://puqme:<password>@<host>:5432/puqme
REDIS_URL=redis://<host>:6379
S3_ENDPOINT=https://storage.idrivee2-7.com
S3_REGION=auto
S3_BUCKET=puq-images
S3_ACCESS_KEY=<idrive-e2-access-key>
S3_SECRET_KEY=<idrive-e2-secret-key>
S3_PUBLIC_BASE_URL=https://cdn.puq.me
STORAGE_AVATARS_BUCKET=puq-avatars
STORAGE_IMAGES_BUCKET=puq-images
STORAGE_CHAT_MEDIA_BUCKET=puq-chat-media
STORAGE_BACKUPS_BUCKET=puq-backups
MEDIA_MAX_UPLOAD_SIZE_BYTES=10485760
MEDIA_MAX_PROFILE_PHOTOS=6
RATE_LIMIT_MAX=250
RATE_LIMIT_WINDOW=1 minute
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_LOGIN_RATE_LIMIT_WINDOW=15 minutes
EXPERIMENT_SALT=<generate-with-openssl-rand-base64-32>
GOOGLE_CLIENT_ID=535490837100-tcscbqgjsgvnbnnrc68hrk15hd6he8m6.apps.googleusercontent.com
